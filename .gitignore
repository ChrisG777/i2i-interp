# Paper-scale binary outputs: gitignore everything under results_v2/ EXCEPT
# the small VLM-judge CSVs (numerical, useful to diff across runs) and the
# auto-generated README (regenerated by `scripts/run_judge.py --write-readme`).
/results_v2/*
!/results_v2/vlm_judge/
/results_v2/vlm_judge/*
!/results_v2/vlm_judge/*.csv
!/results_v2/vlm_judge/README.md
/results_v3/*
!/results_v3/vlm_judge/
/results_v3/vlm_judge/*
!/results_v3/vlm_judge/*.csv
!/results_v3/vlm_judge/README.md
/results_v4/*
!/results_v4/vlm_judge/
/results_v4/vlm_judge/*
!/results_v4/vlm_judge/*.csv
!/results_v4/vlm_judge/README.md
.venv
# /logs/ holds SLURM stdout/stderr — ignore everything inside, but track
# the dir itself via .gitkeep so it exists after `git pull` on the cluster
# (SLURM fails the job if --output points at a missing directory).
/logs/*
!/logs/.gitkeep
