!/data/datasets/*.py
/data/datasets/*/*
!/data/datasets/*/*.py
!/data/datasets/*/README.md
/data/tasks/*/images/*
# Whitelist the 10 DreamBench++ real-human reference images used by the
# dreambench_humans v4 task family (subject_kind=="real_human"). Keep them
# tracked so users don't have to download DreamBench++ to reproduce that
# experiment.
!/data/tasks/customize/images/customize_dreambench_plus_live_subject_human_01_man.jpg
!/data/tasks/customize/images/customize_dreambench_plus_live_subject_human_02_man.jpg
!/data/tasks/customize/images/customize_dreambench_plus_live_subject_human_04_girl.jpg
